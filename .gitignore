# .gitignore - Gabriel Multiloop Agent
# Exclusions complètes pour sécurité

# ============================================================
# SECRETS & CREDENTIALS (CRITIQUE - NE JAMAIS COMMITER)
# ============================================================

# Environment variables
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test

# API Keys & Tokens
*.key
*.pem
*.p8
*.p12
*.pfx
secrets/
.secrets/
credentials.json
api-keys.json
tokens.json

# ============================================================
# FICHIERS SENSIBLES UTILISATEUR
# ============================================================

# Données personnelles
memory/user_data.json
memory/personal_settings.json
memory/*.private
memory/secrets_*

# Logs (peuvent contenir secrets)
logs/
*.log
*.logs

# Local testing
test_secrets.py
test_keys.txt
local_test_*.py

# ============================================================
# CACHES & TEMP FILES
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
ENV/
env/
.venv

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# ============================================================
# DATABASE & CACHE (peuvent contenir données sensibles)
# ============================================================

# Databases
*.db
*.sqlite
*.sqlite3
*.sqlite-journal
*.dbf
*.mdb
*.accdb

# Cache
.cache/
*.cache
.mypy_cache/
.pytest_cache/
.tox/
htmlcov/
.coverage
.coverage.*

# ============================================================
# DONNÉES SENSIBLES GABRIEL
# ============================================================

# Model caches (peuvent être gros + contenir data)
models/
*.model
*.pkl
*.h5

# Memory (peut contenir infos utilisateur)
memory/*.json
memory/*.db
memory/cache/
memory/*.cache

# Validation results (peuvent révéler structure)
data/validation_results/
data/multiloop_results/
results.json

# ============================================================
# FICHIERS SYSTÈME & BUILD
# ============================================================

# OS
.DS_Store
Thumbs.db
.directory
desktop.ini

# Build artifacts
dist/
build/
*.o
*.a
*.so
*.dylib

# Docker
.docker/
docker-compose.override.yml

# ============================================================
# FICHIERS SENSIBLES SPÉCIFIQUES AU PROJET
# ============================================================

# HOL4/Isabelle builds (peuvent être gros)
*.thy.bak
*.thy.tmp
*.sml.bak

# Test reports (peuvent contenir infos)
test_reports/
coverage_reports/

# ============================================================
# FICHIERS À GARDER (whitelisting)
# ============================================================

# GitHub Actions (pas de secrets si bien configuré)
!.github/workflows/

# Documentation (pas de secrets)
!docs/
!README.md
!SETUP.md

# Examples (templates, pas de vrais secrets)
!.env.example
!examples/

# ============================================================
# PATTERNS GÉNERIQUES SENSIBLES
# ============================================================

# Tout fichier contenant "secret" ou "key" sauf exemples
*secret*
!*example*
!*template*
!*sample*

# Tout fichier .local ou .private
*.local
*.private
*.bak
*.backup
# Secrets
.env
.env.*
*.env
*.key
*.pem
*.crt

# Dossiers sensibles
# Note: regles `memory/*` rendues specifiques pour ne PAS ignorer le code
# Python du module RAG (dictionnaire spectral, adaptateur cognitif, sections
# XI/XII de methode_spectral). Seuls les FICHIERS DE DONNEES sensibles sont
# ignores, et ce dans TOUS les sous-dossiers `memory/` (via **/).
**/memory/*.json
**/memory/*.db
**/memory/*.cache
**/memory/cache/
**/memory/secrets_*
**/memory/*.private
**/memory/user_data.json
**/memory/personal_settings.json
__pycache__/

# Logs
*.log
# Gros fichiers de test
test_gabriel_v6.1_gap_mixed.zip
*.zip

# ============================================================
# NOTES IMPORTANTES
# ============================================================

# Ce .gitignore exclut:
# - .env (tous les fichiers d'environnement)
# - Tous les fichiers de secrets/credentials
# - Caches pouvant contenir données
# - Logs pouvant contenir secrets
# - Fichiers sensibles Gabriel/Memory

# Pour utiliser:
# 1. Renommer ce fichier à ".gitignore" (attention: commence par .)
# 2. git rm --cached .env (retirer .env historique)
# 3. git rm --cached memory/*.json (si données sensibles)
# 4. git commit -m "Remove secrets from history"
# 5. Avant chaque push: vérifier rien ne fuite
.credentials
