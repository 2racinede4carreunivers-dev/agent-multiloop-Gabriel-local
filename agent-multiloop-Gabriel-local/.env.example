# ============================================================
# Agent Multi-Loop Mathematique - Exemple de configuration .env
# Copiez ce fichier vers .env et remplissez vos cles.
# ============================================================

# --- Anthropic Claude (LLM prioritaire pour HOL/maths) ---
# Obtenir une cle : https://console.anthropic.com/settings/keys
# La cle commence par : sk-ant-...
CLAUDE_API_KEY=COLLEZ-VOTRE-CLE-ICI
ANTHROPIC_API_KEY=COLLEZ-VOTRE-CLE-ICI
# Modeles disponibles en 2026 :
#   claude-sonnet-4-5-20250929   <- recommande (qualite/cout/vitesse)
#   claude-opus-4-5              <- maximum qualite (plus cher)
CLAUDE_MODEL=claude-sonnet-4-5-20250929
# Plafond d'attente Claude en secondes (defaut 20s).
# Claude prend typiquement 15-25s pour une question HOL/maths.
# 20s = compromis vitesse/fiabilite. Monter a 30s si timeouts frequents.
CLAUDE_TIMEOUT_SECONDS=20

# --- OpenAI (fallback ultime si Claude indisponible) ---
OPENAI_API_KEY=sk-VOTRE-CLE-OPENAI-ICI
OPENAI_MODEL=gpt-4o-mini

# --- Wolfram Alpha (verification numerique independante) ---
# Obtenir un App ID gratuit : https://developer.wolframalpha.com/access
WOLFRAM_APP_ID=VOTRE-WOLFRAM-APP-ID-ICI

# --- Ollama (LLM primaire local) ---
# Sur Windows + Docker Desktop, host.docker.internal pointe sur l'host.
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# --- Configuration agent ---
DEFAULT_LANGUAGE=fr
AGENT_USERNAME=Philippe

# --- Chemins corpus (dans le conteneur) ---
HOL_DIR=/theories
PDF_DIR=/workspace/corpus_actions/pdf
TEX_DIR=/workspace/corpus_actions/tex

# --- GitHub (optionnel - pour bootstrap automatique de depots) ---
GITHUB_USERNAME=
GITHUB_TOKEN=

# --- Multiloop ---
MULTILOOP_MAX_ITERATIONS=3
MULTILOOP_MIN_SCORE=8.0
