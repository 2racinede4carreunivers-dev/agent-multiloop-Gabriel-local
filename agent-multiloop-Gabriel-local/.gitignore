# ============================================================
# .gitignore - Multi-Loop Agent Gabriel Local
# ============================================================

# Environment - NE PAS pousser le vrai .env mais GARDER .env.example
.env
.env.local
.env.*.local
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Logs
logs/
*.log

# Donnees runtime
data/
!data/.gitkeep

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Docker
docker-compose.override.yml

# Isabelle
*.heap
.isabelle/

# Secrets
*.key
*.pem
credentials.json
*token.json*

# Reference du vieil agent (lourd, deja sur disque local)
reference_old_agent/

# ============================================================
# Docker Desktop / WSL virtual disks - JAMAIS dans le repo
# ============================================================
# Ces fichiers (data.vhdx, ext4.vhdx) peuvent depasser 10 Go
# et sont la cause des contextes Docker > 200 Go.
# Ne JAMAIS les committer ni les inclure dans le build.
*.vhdx
*.vhd
*.vmdk
*.qcow2
*.img
**/DockerDesktopWSL/**
**/Docker*Desktop*WSL/**
**/wsl/**/ext4.vhdx
**/wsl/**/data.vhdx
**/Docker/wsl/**
**/DockerData*
**/data.vhdx
**/ext4.vhdx
