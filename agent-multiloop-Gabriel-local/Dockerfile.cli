# =============================================================================
# Multi-Loop Math Agent - Dockerfile.cli (SLIM)
#
# Optimisations vs version precedente :
#   - PAS d'installation d'Isabelle dans l'agent (utilise le service Docker
#     isabelle qui tourne en parallele - communique via volume partage)
#   - Dependances systeme minimales (build-essential + curl + git seulement)
#   - User non-root cree tot
#   - Cache pip optimise (requirements.txt copie en premier)
#   - .dockerignore strict garantit un contexte < 5 Mo
#
# Taille image attendue : ~250-400 Mo (au lieu de 4+ Go avec Isabelle inclus)
# =============================================================================

FROM python:3.11-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONFAULTHANDLER=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

# Dependances systeme minimales (PAS Isabelle ici - service Docker separe)
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# User non-root cree tot
RUN useradd --create-home --shell /bin/bash agent
WORKDIR /home/agent/app

# Cache layer : requirements en premier (rebuild rapide si seul le code change)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt \
    && find /usr/local/lib/python3.11 -name "*.pyc" -delete \
    && find /usr/local/lib/python3.11 -name "__pycache__" -type d -exec rm -rf {} + 2>/dev/null || true

# Code applicatif (apres pip pour bon caching)
COPY --chown=agent:agent main.py main_cli.py config.yaml ./
COPY --chown=agent:agent src/ ./src/

# Dossiers runtime (theories, data, logs montes via volumes)
RUN mkdir -p data logs theories && chown -R agent:agent .

USER agent

VOLUME ["/home/agent/app/data", "/home/agent/app/logs", "/theories"]

CMD ["python", "main_cli.py"]
