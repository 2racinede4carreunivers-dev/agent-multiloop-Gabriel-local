  fixes n :: nat
  assumes "n \<ge> 2"
  assumes "asymetrique_ordonnee A B"
  assumes "length A = n"
  shows "\<exists>C \<lambda>. 0 < \<lambda> \<and> \<lambda> < 1 \<and> ecart_spectral A B \<le> C * \<lambda>^n"
proof -
