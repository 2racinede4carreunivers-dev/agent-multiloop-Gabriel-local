(*
  Fichier ROOT Isabelle - session Methode_Spectral
  Autheur : Philippe Thomas Savard
  Licence : Apache-2.0

  Ce fichier declare la session Isabelle "Methode_Spectral" qui charge
  la theorie methode_spectral.thy avec ses dependances HOL-Computational_Algebra
  (pour beneficier des lemmes sur Primes) et Complex_Main (pour les reels).

  Utilisation locale :
    isabelle build -D . -v

  Utilisation GitHub Actions : voir .github/workflows/build.yml
*)

session "Methode_Spectral" = "HOL-Computational_Algebra" +
  description "
    Formalisation Isabelle/HOL de la Methode Spectrale de Philippe Thomas Savard.
    Rapport spectral 1/2 (1/3, 1/4), digamma calcule, reconstruction du n-ieme
    premier, les 3 piliers bornes a P, Section XI regles de construction.
  "
  options [document = false, timeout = 3600]
  theories
    methode_spectral
